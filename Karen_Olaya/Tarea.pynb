{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyOBvtn1TE6RYZXLOCLQN7Q7"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","execution_count":2,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"n6G_PXvYbgIN","executionInfo":{"status":"ok","timestamp":1775758334978,"user_tz":300,"elapsed":88,"user":{"displayName":"KAREN OLAYA","userId":"07853485491022954139"}},"outputId":"c4e546f0-7346-4a0a-d64b-576d558d56b5"},"outputs":[{"output_type":"stream","name":"stdout","text":["--- Ejecutando Unión de Clases (Estilo Tradicional) ---\n","Usuario: Carlos\n","Producto: Laptop, Precio: $1500000\n","Nuevo precio de Laptop: $1600000\n","--- Ejecutando Unión de Clases (Estilo Moderno) ---\n","Usuario: Maria Paez, Email: Mariap@gmail.com\n","Producto: Teclado, Precio: $50000\n","Nuevo precio actualizado: $55000.0\n"]}],"source":["class Usuario:\n","    def __init__(self, nombre, email, telefono, rol, id_usuario):\n","        self._nombre = nombre\n","        self._email = email\n","        self._telefono = telefono\n","        self._rol = rol\n","        self._id = id_usuario\n","\n","    # Métodos Getters\n","    def get_nombre(self): return self._nombre\n","    def get_email(self): return self._email\n","\n","    # Métodos Setters con validación\n","    def set_nombre(self, nuevo_nombre):\n","        if len(nuevo_nombre) > 0:\n","            self._nombre = nuevo_nombre\n","        else:\n","            print(\"Error: El nombre no puede estar vacío.\")\n","\n","class Catalogo:\n","    def __init__(self, nombre, precio, descripcion, cantidad, codigo, categoria):\n","        self._nombre = nombre\n","        self._precio = precio\n","        self._descripcion = descripcion\n","        self._cantidad = cantidad\n","        self._codigo = codigo\n","        self._categoria = categoria\n","\n","    # Métodos Getters\n","    def get_precio(self): return self._precio\n","    def get_nombre(self): return self._nombre\n","\n","    # Métodos Setters con validación\n","    def set_precio(self, nuevo_precio):\n","        if nuevo_precio >= 0:\n","            self._precio = nuevo_precio\n","        else:\n","            print(\"Error: El precio no puede ser negativo.\")\n","\n","# Programa Principal que \"Une\" ambos conceptos\n","def main():\n","    print(\"--- Ejecutando Unión de Clases (Estilo Tradicional) ---\")\n","\n","    # 1. Instanciar Usuario (5 atributos)\n","    usuario1 = Usuario(\"Carlos\", \"carlos@gmail.com\", \"300123\", \"Admin\", \"U001\")\n","\n","    # 2. Instanciar Catalogo (6 atributos)\n","    item1 = Catalogo(\"Laptop\", 1500000, \"Computador portátil\", 5, \"CAT-01\", \"Electrónica\")\n","\n","    # 3. Demostrar el uso de los métodos tradicionales\n","    print(f\"Usuario: {usuario1.get_nombre()}\")\n","    print(f\"Producto: {item1.get_nombre()}, Precio: ${item1.get_precio()}\")\n","\n","    # 4. Modificar valores usando setters tradicionales\n","    item1.set_precio(1600000)\n","    print(f\"Nuevo precio de {item1.get_nombre()}: ${item1.get_precio()}\")\n","\n","if __name__ == \"__main__\":\n","    main()\n","\n","\n","\n","\n","\n","\n","\n","\n","\n","\n","\n","\n","\n","\n","\n","\n","from dataclasses import dataclass\n","\n","@dataclass\n","class Usuario:\n","    _nombre: str\n","    _email: str\n","    _telefono: str\n","    _rol: str\n","    _id: str\n","\n","    # --- Getters ---\n","    @property\n","    def nombre(self) -> str: return self._nombre\n","    @property\n","    def email(self) -> str: return self._email\n","    @property\n","    def telefono(self) -> str: return self._telefono\n","    @property\n","    def rol(self) -> str: return self._rol\n","    @property\n","    def id_usuario(self) -> str: return self._id\n","\n","    # --- Setters (con validación) ---\n","    @nombre.setter\n","    def nombre(self, valor: str):\n","        if valor and valor.strip(): self._nombre = valor\n","        else: raise ValueError(\"El nombre no puede estar vacío\")\n","\n","    @email.setter\n","    def email(self, valor: str):\n","        if \"@\" in valor: self._email = valor\n","        else: raise ValueError(\"Email inválido\")\n","\n","@dataclass\n","class Catalogo:\n","    _nombre: str\n","    _precio: float\n","    _descripcion: str\n","    _cantidad: int\n","    _codigo: str\n","    _categoria: str\n","\n","    # --- Getters ---\n","    @property\n","    def nombre(self) -> str: return self._nombre\n","    @property\n","    def precio(self) -> float: return self._precio\n","    @property\n","    def codigo(self) -> str: return self._codigo\n","\n","    # --- Setters (con validación) ---\n","    @precio.setter\n","    def precio(self, valor: float):\n","        if isinstance(valor, (int, float)) and valor >= 0:\n","            self._precio = float(valor)\n","        else:\n","            raise ValueError(\"El precio debe ser un número positivo\")\n","\n","# Programa Principal (Unión de ambas clases modernas)\n","def main():\n","    print(\"--- Ejecutando Unión de Clases (Estilo Moderno) ---\")\n","\n","    # Instanciación\n","    usuario = Usuario(\"Maria Paez\", \"Mariap@gmail.com\", \"300123\", \"Vendedor\", \"U-99\")\n","    producto = Catalogo(\"Teclado\", 50000, \"Mecánico RGB\", 20, \"TEC-01\", \"Periféricos\")\n","\n","    # Uso de las propiedades (se accede como si fuera un atributo normal)\n","    print(f\"Usuario: {usuario.nombre}, Email: {usuario.email}\")\n","    print(f\"Producto: {producto.nombre}, Precio: ${producto.precio}\")\n","\n","    # Uso del setter moderno\n","    producto.precio = 55000\n","    print(f\"Nuevo precio actualizado: ${producto.precio}\")\n","\n","if __name__ == \"__main__\":\n","    main()\n","\n","\n","\n","\n","\n","\n","\n","\n","\n","\n","\n","\n","\n","\n","\n","\n"]},{"cell_type":"code","source":["from dataclasses import dataclass\n","\n","# --- 1. USUARIO (Forma Moderna) ---\n","@dataclass\n","class Usuario:\n","    _nombre: str\n","    _email: str\n","    _telefono: str\n","    _rol: str\n","    _id: str\n","\n","    @property\n","    def nombre(self) -> str: return self._nombre\n","\n","    @nombre.setter\n","    def nombre(self, valor: str):\n","        if valor and valor.strip():\n","            self._nombre = valor\n","        else:\n","            raise ValueError(\"El nombre no puede estar vacío\")\n","\n","# --- 2. CATÁLOGO (Forma Tradicional) ---\n","class Catalogo:\n","    def __init__(self, nombre, precio, descripcion, cantidad, codigo, categoria):\n","        self._nombre = nombre\n","        self._precio = precio\n","        self._descripcion = descripcion\n","        self._cantidad = cantidad\n","        self._codigo = codigo\n","        self._categoria = categoria\n","\n","    # Getters\n","    def get_precio(self): return self._precio\n","    def get_nombre(self): return self._nombre\n","\n","    # Setters\n","    def set_precio(self, nuevo_precio):\n","        if isinstance(nuevo_precio, (int, float)) and nuevo_precio >= 0:\n","            self._precio = float(nuevo_precio)\n","        else:\n","            print(\"Error: El precio debe ser positivo.\")\n","\n","# --- Programa Principal (La Unión) ---\n","def main():\n","    print(\"--- Demostración del Cruce Final ---\")\n","\n","    # Usuario (Acceso Moderno)\n","    user = Usuario(\"Maria\", \"maria@mail.com\", \"987654\", \"Editor\", \"U-02\")\n","    user.nombre = \"Maria Lopez\" # Acceso tipo propiedad\n","    print(f\"Usuario (Moderno): {user.nombre}\")\n","\n","    # Catálogo (Acceso Tradicional)\n","    producto = Catalogo(\"Tablet\", 300000, \"Tablet Android\", 5, \"T-100\", \"Tech\")\n","    producto.set_precio(320000) # Acceso vía método\n","    print(f\"Producto (Tradicional): {producto.get_nombre()}, Precio: ${producto.get_precio()}\")\n","\n","if __name__ == \"__main__\":\n","    main()\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"5rjynuN-cQOm","executionInfo":{"status":"ok","timestamp":1775758409457,"user_tz":300,"elapsed":326,"user":{"displayName":"KAREN OLAYA","userId":"07853485491022954139"}},"outputId":"a4f45207-5a22-480a-d6d4-8166654c8ce8"},"execution_count":4,"outputs":[{"output_type":"stream","name":"stdout","text":["--- Demostración del Cruce Final ---\n","Usuario (Moderno): Maria Lopez\n","Producto (Tradicional): Tablet, Precio: $320000.0\n"]}]}]}