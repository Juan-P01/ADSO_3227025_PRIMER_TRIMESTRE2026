{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyOSHia8dNUaD8atvAbtEmqn"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","source":["import random\n","nombre = [\"Kelly\",\"Crisrian\",\"Nelson\",\"Sr paka\",\"Ñaño\", \"Sebastian\"]\n","\n","nombre_secreto = random.choice(nombre)\n","print(\"===Adivina el CHATO===\")\n","print(\"Tiene 3 intentos de vida...\")\n","vidas = 3\n","while vidas > 0:\n","    intento = input(\"ingrese el nombre del CHATO\")\n","    if intento.lower() == nombre_secreto.lower():\n","         print(\"CHATO ganaste, Adivinaste el nombre...\")\n","         break\n","    else:\n","      vidas -= 1\n","      print(\"ERROR CRITICO,el nombre del CHATO no es intentos.fallidos:\", vidas)\n","if vidas ==0:\n","  print(\"PAILAS,PERDISTE EL NOMBRE ERA:\",nombre_secreto,\"ahora consigna a mi nequi...\")"],"metadata":{"id":"qG4IJlZAcCH6"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["#Ejercicio de gestion de clientes en una tienda\n","#Agregar nuevos clientes\n","#Recorrer la lista y mostrar todos los datos\n","#Modificar un nombre en caso de error\n","#Eliminar un cliente\n","\n","#Funciones que utilizaremos\n","#Len() -> Cuenta las instacias dentro de la lista\n","#append() Añade daros a la lista\n","#title() Coloca el primer caracter en #Mayusculas ej, carlos - Carlos\n","#pop() Elimina los datos de la lista\n","\n","#Agregar uevos clientes\n","def agregar_clientes(lista_clientes, nombre):\n","    #Verificamos si eel dato ingreado es una cadena y longitud valida entre 2 a 50 caracteres\n","    if isinstance(nombre, str) and 2 <= len(nombre) <= 50:\n","        # Si el nombre cumple\n","        lista_clientes.append(nombre.title())\n","        print(f\"Cliente agregado: {nombre.title()}\")\n","    else: #El nombre ingresado no cumple con la validacion entonces\n","        print(\"Nombre del cliente invalido detener entre 2 a 50 caracteres\")\n","def mostra_clientes(lista_clientes):\n","  for cliente in lista_clientes:\n","      print(f\" - {cliente}\")\n","def modificar_cliente(lista_clientes, indice, nuevo_nombre):\n","     #Verificamos si el dato ingresado es una cadena y longitud valida entre 2 a 50 caracteres\n","      if not (isinstance(nuevo_nombre, str) and 2 <= len(nuevo_nombre) <= 50):\n","          print(\"Nombre del cliente inválido; debe tener entre 2 a 50 caracteres.\")\n","          return\n","      # Verificar si el indice es válido\n","      if 0 <= indice < len(lista_clientes):\n","         original = lista_clientes[indice]\n","         lista_clientes[indice] = nuevo_nombre.title()\n","         print(f\"El Cliente {original} fue modificado por: {nuevo_nombre.title()}\")\n","      else:\n","         print(\"No existe ese cliente en la lista.\")\n","#Elimina un cliente\n","def eliminar_cliente(lista_clientes, indice):\n","    if 0 <= indice <= len(lista_clientes):\n","        eliminado = lista_clientes.pop(indice) #Elimina el cliente de acuerdo al numero de indice\n","        #Mostraremos el registro eliminado\n","        print(f\"Cliente eliminado: {eliminado}\")\n","    else:\n","        print(\"No existe ese cliente en nuestro sistema.\")\n","def main():\n","    clientes =[\"Kelly\",\"Cristian\",\"Nelson\",\"Sr paka\",\"Ñaño\",\"Sebastian\"]\n","    print(\"Clientes activos\")\n","    mostra_clientes(clientes)\n","    agregar_clientes(clientes, \"Alejandro\")\n","    print(\"Clientes activos\")\n","    mostra_clientes(clientes)\n","    modificar_cliente(clientes,4,\"Gabriela\")\n","    mostra_clientes(clientes)\n","    eliminar_cliente(clientes,3)\n","    mostra_clientes(clientes)\n","\n","if __name__ == \"__main__\":\n","    main()\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Pnle097uciFj","executionInfo":{"status":"ok","timestamp":1774559034648,"user_tz":300,"elapsed":50,"user":{"displayName":"KAREN OLAYA","userId":"07853485491022954139"}},"outputId":"6c160e5f-b856-4403-9e46-11329dad5f8b"},"execution_count":13,"outputs":[{"output_type":"stream","name":"stdout","text":["Clientes activos\n"," - Kelly\n"," - Cristian\n"," - Nelson\n"," - Sr paka\n"," - Ñaño\n"," - Sebastian\n","Cliente agregado: Alejandro\n","Clientes activos\n"," - Kelly\n"," - Cristian\n"," - Nelson\n"," - Sr paka\n"," - Ñaño\n"," - Sebastian\n"," - Alejandro\n","El Cliente Ñaño fue modificado por: Gabriela\n"," - Kelly\n"," - Cristian\n"," - Nelson\n"," - Sr paka\n"," - Gabriela\n"," - Sebastian\n"," - Alejandro\n","Cliente eliminado: Sr paka\n"," - Kelly\n"," - Cristian\n"," - Nelson\n"," - Gabriela\n"," - Sebastian\n"," - Alejandro\n"]}]},{"cell_type":"code","source":["def agregar_animales(lista_animales, nombre):\n","    #Verificamos si el dato ingresado es una cadena y longitud valida entre 2 a 50 caracteres\n","    if isinstance(nombre, str) and 2 <= len(nombre) <= 50:\n","        # Si el nombre cumple\n","        lista_animales.append(nombre.title())\n","        print(f\"Animal agregado: {nombre.title()}\")\n","    else: #El nombre ingresado no cumple con la validacion entonces\n","        print(\"Nombre del animal invalido, debe tener entre 2 a 50 caracteres\")\n","def mostra_animales(lista_animales):\n","  for animal in lista_animales:\n","      print(f\" - {animal}\")\n","def modificar_animales(lista_animales, indice, nuevo_nombre):\n","     #Verificamos si el dato ingresado es una cadena y longitud valida entre 2 a 50 caracteres\n","      if not (isinstance(nuevo_nombre, str) and 2 <= len(nuevo_nombre) <= 50):\n","          print(\"Nombre del animal inválido; debe tener entre 2 a 50 caracteres.\")\n","          return\n","      # Verificar si el indice es válido\n","      if 0 <= indice < len(lista_animales):\n","         original = lista_animales[indice]\n","         lista_animales[indice] = nuevo_nombre.title()\n","         print(f\"El Animal {original} fue modificado por: {nuevo_nombre.title()}\")\n","      else:\n","         print(\"No existe ese animal en la lista.\")\n","#Elimina un animal\n","def eliminar_animal(lista_animales, indice):\n","    if 0 <= indice < len(lista_animales):\n","        eliminado = lista_animales.pop(indice) #Elimina el animal de acuerdo al numero de indice\n","        #Mostraremos el registro eliminado\n","        print(f\"Animal eliminado: {eliminado}\")\n","    else:\n","        print(\"No existe ese animal en nuestro sistema.\")\n","def main():\n","    animales =[\"Toby\",\"Gruñon\",\"Beky\",\"Chiquitin\",\"Pacho\",\"Garrapata\"]\n","    print(\"Animales activos\")\n","    mostra_animales(animales)\n","    agregar_animales(animales, \"Mechas\")\n","    agregar_animales(animales, \"Tony\")\n","    agregar_animales(animales, \"Lulu\")\n","    eliminar_animal(animales,1)\n","    eliminar_animal(animales,4)\n","    mostra_animales(animales)\n","\n","if __name__ == \"__main__\":\n","    main()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"4WS6Gk2Uya8V","executionInfo":{"status":"ok","timestamp":1774562584167,"user_tz":300,"elapsed":6,"user":{"displayName":"KAREN OLAYA","userId":"07853485491022954139"}},"outputId":"152963dc-dc19-4d58-acd2-3b0ae4698eb7"},"execution_count":20,"outputs":[{"output_type":"stream","name":"stdout","text":["Animales activos\n"," - Toby\n"," - Gruñon\n"," - Beky\n"," - Chiquitin\n"," - Pacho\n"," - Garrapata\n","Animal agregado: Mechas\n","Animal agregado: Tony\n","Animal agregado: Lulu\n","Animal eliminado: Gruñon\n","Animal eliminado: Garrapata\n"," - Toby\n"," - Beky\n"," - Chiquitin\n"," - Pacho\n"," - Mechas\n"," - Tony\n"," - Lulu\n"]}]},{"cell_type":"code","source":["#Metodos comunes que utilizaremos\n","#.append()\n","#.insert()\n","#.remove() /pop()\n","#sort() ordena la lista por el dato que lo le indique\n","#reverse() invertir los datos de la lista\n","#EJERCICIO INVENTARIO DE UN FERRETERIA\n","# ===\n","# 1. INGRESAR NUEVOS PRODUCTOS\n","# 2. INSERTAR PRODUCTOS\n","# 3. ELIMINAR PRODUCTOS AGOTADOS\n","# 4. ORDENA PRODUCTOS POR NOMBRE Y PRECIO\n","# 5. INVERTIR ORDEN DE PRESENTACION DE LOS PRODUCTOS\n","# Requisitos del sistema\n","#    -Lista debe tener nombre y precio\n","#    -validacion de entardas\n","# ===\n","\n","def mostrar_inventario(productos):\n","    print(\"===INVENTARIO ACTUAL===\")\n","    if not productos:\n","      print(\"No hay productos registrados\")\n","      return\n","    for i, producto in enumerate(productos, start=1):\n","        # Corrected f-string usage and combined into one print for clarity\n","        print(f\"[{i}. {producto['nombre']}] - ${producto['precio']:.2f}\")\n","\n","\n","def main():\n","  inventario = [\n","      {\"nombre\": \"Taladro\",\"precio\":150000},\n","      {\"nombre\": \"Martillo\",\"precio\":4000},\n","      {\"nombre\": \"Destornillador\",\"precio\":15000}\n","  ]\n","  # Example of how to use mostrar_inventario\n","  mostrar_inventario(inventario)\n","\n","if __name__ == \"__main__\":\n","    main()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"tZygDwZILEHt","executionInfo":{"status":"ok","timestamp":1774564456789,"user_tz":300,"elapsed":4,"user":{"displayName":"KAREN OLAYA","userId":"07853485491022954139"}},"outputId":"f9c9307a-a136-454f-9364-cc2d8ed7c61e"},"execution_count":24,"outputs":[{"output_type":"stream","name":"stdout","text":["===INVENTARIO ACTUAL===\n","[1. Taladro] - $150000.00\n","[2. Martillo] - $4000.00\n","[3. Destornillador] - $15000.00\n"]}]},{"cell_type":"code","source":[],"metadata":{"id":"-PopEHx1Pnjn","executionInfo":{"status":"ok","timestamp":1774563785499,"user_tz":300,"elapsed":56,"user":{"displayName":"KAREN OLAYA","userId":"07853485491022954139"}}},"execution_count":22,"outputs":[]}]}